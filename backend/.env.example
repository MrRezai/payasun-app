# ─── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=payasun_db

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=7d

# ─── MeliPayamak SMS Gateway ─────────────────────────────
MELIPAYAMAK_USERNAME=your_username
MELIPAYAMAK_PASSWORD=your_password
MELIPAYAMAK_BODY_ID=your_body_id

# ─── SMS Debug Mode ──────────────────────────────────────
# Set to 'true' in production. When 'false', OTP codes are
# logged to console and returned in the API response.
SMS_ENABLED=false
# ─── Application ─────────────────────────────────────────
APP_PORT=3000

# ─── Admin Credentials ───────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpassword
